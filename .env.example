# Required: local CKB node RPC endpoint (per-node deployment)
CKB_NODE_RPC_URL=http://127.0.0.1:8114

# Required: chain label used by Prometheus/Grafana filtering (mainnet/testnet/preview)
CHAIN=mainnet

# Required: unique node identifier label
NODE_NAME=mainnet-us-east-1

# Optional: node type label for Grafana filtering (bootnode/public, default: public)
NODE_TYPE=public

# Optional: explicit node IP/hostname label (defaults to hostname from CKB_NODE_RPC_URL)
NODE_IP=mainnet-node-1

# Optional: geographic location label
NODE_LOCATION=us-east-1

# Optional: host port for Docker port mapping (default: 8090)
# The container always listens internally on port 8090
EXPORTER_PORT=8090

# Optional: exporter bind host (default: 0.0.0.0, only for bare-metal python run.py)
# EXPORTER_HOST=0.0.0.0

# Optional: logging level (default: INFO)
LOG_LEVEL=INFO

# Optional: RPC timeout in seconds (default: 10)
RPC_TIMEOUT=10

# Optional: comma-separated bootnode IP list for maintainer ban tracking.
# If empty/unset, ban bootnode metric reports 0.
BOOTNODES=13.236.13.195,34.216.103.183
